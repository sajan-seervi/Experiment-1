#EXPERIMENT 3: WAP TO IMPLEMENT VARIOUS STRING OPERATIONS

AIM: to write a Python program to demonstrates various string operations 

ALGORITHM:
STEP 1: start the program
STEP 2: input a string from the user
STEP 3: display the original string and its length
STEP 4: covert the string to uppercase and lowercase
STEP 5: input  substring and find its position in the string
STEP 6: perform the string operations 
STEP 7; display the results 
STEP 8: stop the program


#CODE

s = input("Enter a string: ")
print("Original string:", s)

print("Length of string:", len(s))

print("Uppercase:", s.upper())
print("Lowercase:", s.lower())

sub = input("Enter a substring to find: ")
print("Position:", s.find(sub))

old = input("Enter the old string: ")
new = input("Enter the new string: ")
print("After replacement:", s.replace(old, new))

print("Split string:", s.split())

str1 = input("Enter first string: ")
str2 = input("Enter second string: ")

concat = str1 + str2
print("Concatenation:", concat)

print("Is Alphabetic?", concat.isalpha())
print("Is Numeric?", concat.isdigit())


