#EXPERIMENT 4: WAP TO IMPLEMENT DEMONSTRATE LIST AND RELATED FUNCTIONS IN PYTHON 

AIM: to write a Python program to demonstrates list operations and related functions such as append,extend and etc

ALGORITHM:
STEP 1: start the program
STEP 2: create a list with some elements
STEP 3: add elements using append(),extend() and insert()
STEP 4: remove elements using remove() and pop()
STEP 5: find index and count of elements
STEP 6: copy the list using copy() and clear the list using clear()
STEP 7; display the results 
STEP 8: stop the program

CODE

keyword = ["sushi", "max", "rahul", "network"]
print("Initial list:", keyword)

keyword.append("rohan")
keyword.extend("maxwell")
keyword.insert(1, "pat cummins")
keyword.remove("network")

removed_item = keyword.pop(2)

index_position = keyword.index("rohan")
count_rahul = keyword.count("rahul")

print("List before clear():", keyword)

copied_list = keyword.copy()
keyword.clear()

print("Final list:", keyword)
print("Removed item:", removed_item)
print("Index of rohan:", index_position)
print("Count of rahul:", count_rahul)
print("Copied list:", copied_list)


